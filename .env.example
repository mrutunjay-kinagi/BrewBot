# Get this from https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# Optional: override the default free catalog model and API base URL
NVIDIA_MODEL=google/gemma-3n-e2b-it
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Railway sets PORT automatically; for local dev it defaults to 8000
PORT=8000
